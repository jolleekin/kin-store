#!/bin/sh
# Require a version bump in deno.json when package source files change.

PACKAGES="core plugins react"
FAIL=0

for pkg in $PACKAGES; do
  src_changed=$(git diff --cached --name-only | grep "^$pkg/" | grep -v "^$pkg/deno\.json")
  if [ -n "$src_changed" ]; then
    version_staged=$(git diff --cached --name-only | grep "^$pkg/deno\.json")
    if [ -z "$version_staged" ]; then
      echo "error: $pkg has staged changes but $pkg/deno.json version was not bumped"
      FAIL=1
    fi
  fi
done

deno lint || FAIL=1
deno test -A core plugins react || FAIL=1

exit $FAIL
